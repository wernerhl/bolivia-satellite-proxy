# Bolivia satellite-proxy pipeline — reuses Haiti/Gaza infrastructure.
# GCP project, bucket, and service-account key are shared; Bolivia outputs
# live under gs://$GCS_BUCKET/bolivia/ (VIIRS SOL, S5P NO2) to keep the
# blast radius isolated from Haiti assets.

# --- GCP / Earth Engine (shared with whl.Haiti) -----------------------
GCP_PROJECT_ID=haiti-poverty-monitoring
GCS_BUCKET=haiti-sae-2026
GOOGLE_APPLICATION_CREDENTIALS=/Users/whl/secrets/haiti-sae-runner.json

# --- EOG Nightfire (VNF) ---------------------------------------------
# Earthdata bearer token; refresh 48h before expiry (60-day cadence).
# Request at https://eogdata.mines.edu/ — not on GEE.
EOG_TOKEN=

# --- GitHub (shared pattern; distinct repo) --------------------------
GH_USER=wernerhl
GH_REPO=bolivia-satellite-proxy
GH_PAT=

# --- Paths ------------------------------------------------------------
PROJECT_ROOT=/Users/whl/Documents/whl.BoliviaSatellite
